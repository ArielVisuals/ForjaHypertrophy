---
import MainLayout from "@/layouts/MainLayout.astro";
import { PasswordRecovery } from "@/components/auth/PasswordRecovery";
---

<MainLayout title="Recuperar contraseña" description="Solicita un enlace para restablecer tu contraseña de FORJA." showHeader={false}>
  <div class="relative min-h-[80vh] flex items-center justify-center px-4 py-10">
    <div class="w-full max-w-md space-y-8">
      <div class="text-center space-y-2">
        <a href="/" class="inline-flex items-center justify-center gap-3 mb-4">
          <img src="/isotipo.png" alt="FORJA" width="2048" height="2048" class="h-10 w-auto" />
          <span class="text-2xl font-extrabold text-white tracking-tighter">FORJA</span>
        </a>
        <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tighter leading-none">
          Recupera<span class="text-white/20"> tu acceso</span>
        </h1>
        <p class="text-white/30 text-xs font-bold uppercase tracking-widest pt-1">
          Te enviaremos un enlace de 30 minutos
        </p>
      </div>
      <div class="p-6 sm:p-10 rounded-[2.5rem] bg-[#0A0A0B] border border-white/10">
        <PasswordRecovery mode="request" client:load />
      </div>
    </div>
  </div>
</MainLayout>

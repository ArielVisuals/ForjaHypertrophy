---
import "../styles/global.css";
import { LandingHeader } from "@/components/shared/LandingHeader";
import { FluidGraphic } from "@/components/shared/FluidGraphic";
import { InstallAppButton } from "@/components/shared/InstallAppButton";

// Si el usuario ya esta autenticado, redirigir a su panel
const user = Astro.locals.user;
if (user) {
  return Astro.redirect(user.role === "coach" ? "/coach" : "/dashboard");
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FORJA es la app de entrenamiento para hipertrofia — registra series, analiza progreso y optimiza cada sesión con inteligencia artificial." />
    <title>FORJA Hypertrophy - Transforma tu físico</title>
    <!-- PWA: necesario para que el navegador ofrezca instalar desde la landing -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="FORJA" />
    <meta name="theme-color" content="#0A0A0B" />
    <meta name="mobile-web-app-capable" content="yes" />
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    </noscript>
    <script is:inline>
      // Immediate execution to prevent scroll jumps
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);
      
      // Secondary check once DOM is ready but before full load
      document.addEventListener('DOMContentLoaded', () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
        }
      });
    </script>
  </head>
  <body class="min-h-screen relative overflow-x-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-black"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-950/20 to-indigo-950/30"></div>

    <!-- Animated Floating Header -->
    <LandingHeader client:load />

    <!-- Hero Section -->
    <section id="hero" class="relative z-10 pt-[clamp(6rem,15vh,10rem)] pb-[clamp(4rem,10vh,8rem)]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center space-y-[clamp(2rem,5vw,3rem)]">
          <!-- Badge -->
          <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/[0.03] border border-white/10 text-[clamp(0.75rem,1.5vw,0.875rem)] font-medium text-white/80">
            <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></span>
            <span>Plataforma de Hipertrofia Inteligente</span>
          </div>

          <!-- Main Heading -->
          <h1 class="text-[clamp(2.5rem,10vw,7rem)] font-black leading-[1.05] tracking-tight">
            <span class="text-white">Transforma</span>
            <br />
            <span class="text-gradient-animated">tu físico</span>
          </h1>

          <!-- Description -->
          <p
            class="text-[clamp(1.125rem,1.5vw,1.35rem)] text-white/60 leading-relaxed max-w-5xl mx-auto"
          >
            Trackea tus workouts, mide tu progreso y alcanza tus metas de hipertrofia con nuestra plataforma diseñada para atletas serios.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-[clamp(1rem,3vw,1.5rem)] pt-4">
            <a 
              href="/register"
              class="group w-full sm:w-auto px-10 py-5 rounded-full text-[clamp(1rem,1.5vw,1.125rem)] font-bold text-white bg-blue-600/20 hover:bg-blue-600/30 backdrop-blur-xl border border-blue-500/30 hover:border-blue-500/50 transition-all shadow-[0_0_30px_rgba(37,99,235,0.15)] hover:scale-105 flex items-center justify-center gap-3 cursor-pointer"
            >
              Comenzar Ahora 
              <svg class="w-5 h-5 transition-transform duration-500 group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <div class="w-full sm:w-auto">
              <InstallAppButton client:load />
            </div>
          </div>

          <!-- Stats -->
          <div class="relative pt-[clamp(2rem,8vw,4rem)] pb-20">
            <!-- Grid Background for Stats -->
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff03_1px,transparent_1px),linear-gradient(to_bottom,#ffffff03_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] pointer-events-none"></div>
            
            <div class="relative grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-[clamp(2rem,6vw,4rem)] max-w-5xl mx-auto px-6">
              <!-- Stat 1 -->
              <div class="flex flex-col items-center justify-center text-center group">
                <div class="relative inline-flex flex-col items-center justify-center">
                  <div class="text-[clamp(4rem,12vw,7rem)] font-black tracking-tighter leading-none bg-clip-text text-transparent bg-gradient-to-b from-white from-35% via-white/50 to-black to-75% select-none transition-transform duration-500 group-hover:scale-[1.02]">
                    500+
                  </div>
                  <div class="absolute bottom-[-5%] w-full flex justify-center z-10">
                    <div class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-white tracking-tight drop-shadow-[0_8px_16px_rgba(0,0,0,1)] leading-none">
                      ejercicios
                    </div>
                  </div>
                </div>
                <div class="mt-[clamp(2rem,6vw,3rem)] text-[10px] md:text-xs text-white/40 font-bold uppercase tracking-widest max-w-[150px] leading-tight">
                  Biblioteca Pro
                </div>
              </div>

              <!-- Stat 2 -->
              <div class="flex flex-col items-center justify-center text-center group">
                <div class="relative inline-flex flex-col items-center justify-center">
                  <div class="text-[clamp(4rem,12vw,7rem)] font-black tracking-tighter leading-none bg-clip-text text-transparent bg-gradient-to-b from-white from-35% via-white/50 to-black to-75% select-none transition-transform duration-500 group-hover:scale-[1.02]">
                    1000+
                  </div>
                  <div class="absolute bottom-[-5%] w-full flex justify-center z-10">
                    <div class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-white tracking-tight drop-shadow-[0_8px_16px_rgba(0,0,0,1)] leading-none">
                      usuarios
                    </div>
                  </div>
                </div>
                <div class="mt-[clamp(2rem,6vw,3rem)] text-[10px] md:text-xs text-white/40 font-bold uppercase tracking-widest max-w-[150px] leading-tight">
                  Comunidad Activa
                </div>
              </div>

              <!-- Stat 3 -->
              <div class="flex flex-col items-center justify-center text-center group">
                <div class="relative inline-flex flex-col items-center justify-center">
                  <div class="text-[clamp(4rem,12vw,7rem)] font-black tracking-tighter leading-none bg-clip-text text-transparent bg-gradient-to-b from-white from-35% via-white/50 to-black to-75% select-none transition-transform duration-500 group-hover:scale-[1.02]">
                    24/7
                  </div>
                  <div class="absolute bottom-[-5%] w-full flex justify-center z-10">
                    <div class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-white tracking-tight drop-shadow-[0_8px_16px_rgba(0,0,0,1)] leading-none">
                      tracking
                    </div>
                  </div>
                </div>
                <div class="mt-[clamp(2rem,6vw,3rem)] text-[10px] md:text-xs text-white/40 font-bold uppercase tracking-widest max-w-[150px] leading-tight">
                  Soporte Total
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="relative z-10 py-[clamp(4rem,10vw,8rem)] @container">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center space-y-4 mb-[clamp(3rem,8vw,5rem)]">
          <h2 class="text-[clamp(2.5rem,7vw,5rem)] font-black text-white leading-tight">
            Todo lo que necesitas
          </h2>
          <p
            class="text-[clamp(1.125rem,2vw,1.25rem)] text-white/70 max-w-4xl mx-auto"
          >
            Herramientas profesionales para llevar tu entrenamiento al siguiente nivel
          </p>
        </div>

        <!-- Feature Grid - Modern Auto-fit -->
        <div class="grid grid-cols-[repeat(auto-fit,minmax(min(100%,350px),1fr))] gap-6 @container">
          <!-- Feature 1 -->
          <div class="group relative p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2rem] bg-[#0A0A0B] border border-white/10 hover:border-white/20 transition-all duration-500 overflow-hidden @container">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative space-y-[clamp(1rem,3cqw,1.5rem)]">
              <div class="w-[clamp(2.5rem,8cqw,3.5rem)] h-[clamp(2.5rem,8cqw,3.5rem)] rounded-xl bg-blue-500/10 flex items-center justify-center border border-blue-500/20 shadow-[0_0_20px_rgba(59,130,246,0.15)]">
                <svg class="w-[50%] h-[50%] text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="text-[clamp(1.25rem,4cqw,1.5rem)] font-bold text-white tracking-tight">Tracking Inteligente</h3>
                <p class="text-[clamp(0.875rem,2.5cqw,1rem)] text-white/50 leading-relaxed">
                  Registra cada serie, rep y peso. Analiza tu progreso con gráficos detallados y métricas avanzadas.
                </p>
              </div>
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="group relative p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2rem] bg-[#0A0A0B] border border-white/10 hover:border-white/20 transition-all duration-500 overflow-hidden @container">
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative space-y-[clamp(1rem,3cqw,1.5rem)]">
              <div class="w-[clamp(2.5rem,8cqw,3.5rem)] h-[clamp(2.5rem,8cqw,3.5rem)] rounded-xl bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20 shadow-[0_0_20px_rgba(16,185,129,0.15)]">
                <svg class="w-[50%] h-[50%] text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="text-[clamp(1.25rem,4cqw,1.5rem)] font-bold text-white tracking-tight">Programas de Élite</h3>
                <p class="text-[clamp(0.875rem,2.5cqw,1rem)] text-white/50 leading-relaxed">
                  Crea y sigue programas diseñados específicamente para tus objetivos de hipertrofia y fuerza.
                </p>
              </div>
            </div>
          </div>

          <!-- Feature 3 -->
          <div class="group relative p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2rem] bg-[#0A0A0B] border border-white/10 hover:border-white/20 transition-all duration-500 overflow-hidden @container">
            <div class="absolute inset-0 bg-gradient-to-br from-orange-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative space-y-[clamp(1rem,3cqw,1.5rem)]">
              <div class="w-[clamp(2.5rem,8cqw,3.5rem)] h-[clamp(2.5rem,8cqw,3.5rem)] rounded-xl bg-orange-500/10 flex items-center justify-center border border-orange-500/20 shadow-[0_0_20px_rgba(249,115,22,0.15)]">
                <svg class="w-[50%] h-[50%] text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14l2.828 2.828z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="text-[clamp(1.25rem,4cqw,1.5rem)] font-bold text-white tracking-tight">Racha de Poder</h3>
                <p class="text-[clamp(0.875rem,2.5cqw,1rem)] text-white/50 leading-relaxed">
                  Mantén tu consistencia con nuestro sistema de rachas. Nunca más pierdas tu momentum.
                </p>
              </div>
            </div>
          </div>

          <!-- Feature 4 -->
          <div class="group relative p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2rem] bg-[#0A0A0B] border border-white/10 hover:border-white/20 transition-all duration-500 overflow-hidden @container">
            <div class="absolute inset-0 bg-gradient-to-br from-purple-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative space-y-[clamp(1rem,3cqw,1.5rem)]">
              <div class="w-[clamp(2.5rem,8cqw,3.5rem)] h-[clamp(2.5rem,8cqw,3.5rem)] rounded-xl bg-purple-500/10 flex items-center justify-center border border-purple-500/20 shadow-[0_0_20px_rgba(168,85,247,0.15)]">
                <svg class="w-[50%] h-[50%] text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="text-[clamp(1.25rem,4cqw,1.5rem)] font-bold text-white tracking-tight">Métricas Avanzadas</h3>
                <p class="text-[clamp(0.875rem,2.5cqw,1rem)] text-white/50 leading-relaxed">
                  Registra peso, perímetros y fotos de progreso. Visualiza tu transformación física mes a mes.
                </p>
              </div>
            </div>
          </div>

          <!-- Feature 5 -->
          <div class="group relative p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2rem] bg-[#0A0A0B] border border-white/10 hover:border-white/20 transition-all duration-500 overflow-hidden @container">
            <div class="absolute inset-0 bg-gradient-to-br from-yellow-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative space-y-[clamp(1rem,3cqw,1.5rem)]">
              <div class="w-[clamp(2.5rem,8cqw,3.5rem)] h-[clamp(2.5rem,8cqw,3.5rem)] rounded-xl bg-yellow-500/10 flex items-center justify-center border border-yellow-500/20 shadow-[0_0_20px_rgba(234,179,8,0.15)]">
                <svg class="w-[50%] h-[50%] text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="text-[clamp(1.25rem,4cqw,1.5rem)] font-bold text-white tracking-tight">Macros & Nutrición</h3>
                <p class="text-[clamp(0.875rem,2.5cqw,1rem)] text-white/50 leading-relaxed">
                  Trackea macros y calorías. Optimiza tu nutrición para maximizar tu ganancia muscular.
                </p>
              </div>
            </div>
          </div>

          <!-- Feature 6 -->
          <div class="group relative p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2rem] bg-[#0A0A0B] border border-white/10 hover:border-white/20 transition-all duration-500 overflow-hidden @container">
            <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative space-y-[clamp(1rem,3cqw,1.5rem)]">
              <div class="w-[clamp(2.5rem,8cqw,3.5rem)] h-[clamp(2.5rem,8cqw,3.5rem)] rounded-xl bg-indigo-500/10 flex items-center justify-center border border-indigo-500/20 shadow-[0_0_20px_rgba(99,102,241,0.15)]">
                <svg class="w-[50%] h-[50%] text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="text-[clamp(1.25rem,4cqw,1.5rem)] font-bold text-white tracking-tight">Récords Personales</h3>
                <p class="text-[clamp(0.875rem,2.5cqw,1rem)] text-white/50 leading-relaxed">
                  Celebra cada PR. El sistema guarda automáticamente tus récords personales en cada ejercicio.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="relative z-10 py-[clamp(4rem,12vw,10rem)] @container">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center space-y-4 mb-[clamp(3rem,10vw,6rem)]">
          <h2 class="text-[clamp(2.5rem,7vw,5rem)] font-black text-white leading-tight">
            Planes de Entrenamiento
          </h2>
          <p
            class="text-[clamp(1.125rem,1.5vw,1.25rem)] text-white/70 max-w-5xl mx-auto"
          >
            Invierte en tu físico con herramientas de élite diseñadas para maximizar la hipertrofia muscular y el rendimiento atlético.
          </p>
        </div>

        <div class="grid grid-cols-[repeat(auto-fit,minmax(min(100%,340px),1fr))] gap-[clamp(1.5rem,3vw,2rem)] items-stretch">
          <!-- Basic Plan -->
          <div class="group relative p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2.5rem] bg-[#0A0A0B] border border-white/10 hover:border-white/20 transition-all duration-500 flex flex-col h-full overflow-hidden @container">
            <div class="relative z-10 space-y-8 flex-grow">
              <div class="space-y-2">
                <h3 class="text-[clamp(1.25rem,4cqw,1.5rem)] font-bold text-white">Esencial</h3>
                <p class="text-white/55 text-sm">Ideal para principiantes enfocados en la técnica.</p>
              </div>
              
              <div class="relative inline-flex items-end">
                <span class="text-[clamp(3.5rem,8cqw,4.5rem)] font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-b from-white from-50% to-black leading-none">
                  $0
                </span>
                <span class="text-xs font-bold text-white/55 uppercase tracking-widest ml-2 mb-1">/mes</span>
              </div>

              <div class="space-y-4 py-6 border-t border-white/5">
                <ul class="space-y-4">
                  <li class="flex items-center gap-3 text-white/70">
                    <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm font-medium">3 rutinas semanales</span>
                  </li>
                  <li class="flex items-center gap-3 text-white/70">
                    <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm font-medium">Biblioteca 500+ ejercicios</span>
                  </li>
                  <li class="flex items-center gap-3 text-white/70">
                    <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm font-medium">Historial básico</span>
                  </li>
                </ul>
              </div>
            </div>

            <a 
              href="/register"
              class="relative z-10 mt-8 w-full py-4 px-6 rounded-2xl text-center font-bold text-white border border-white/10 bg-white/5 hover:bg-white/10 transition-all cursor-pointer text-sm"
            >
              Comenzar Gratis
            </a>
          </div>

          <!-- Pro Plan -->
          <div class="group relative p-[1px] rounded-[2.5rem] bg-gradient-to-b from-blue-500/50 via-blue-500/10 to-transparent transition-all duration-500 hover:scale-[1.02] @container">
            <div class="relative h-full p-[clamp(1.5rem,4cqw,2.5rem)] rounded-[2.4rem] bg-[#0A0A0B] flex flex-col overflow-hidden">
              <div class="absolute top-0 right-0 w-64 h-64 bg-blue-600/10 blur-[100px] -z-10"></div>
              
              <div class="relative z-10 space-y-8 flex-grow">
                <div class="space-y-4">

---
import MainLayout from "@/layouts/MainLayout.astro";
import { IntakeReview } from "@/components/coach/IntakeReview";
import { CoachWorkoutLog } from "@/components/coach/CoachWorkoutLog";
import { AssignProgram } from "@/components/coach/AssignProgram";
import { getOwnedAthlete, getAthleteIntake } from "@/lib/db/coach";
import { getActiveProgramWithSchedule, getProgramLibrary } from "@/lib/db/programs";
import { getWorkoutHistory } from "@/lib/db/workouts";
import { getWeeklyNutritionSummary, getActiveNutritionTargets } from "@/lib/db/nutrition";
import { getActiveMealPlan } from "@/lib/db/mealPlans";

const coach = Astro.locals.user!;
const athleteId = Astro.params.id!;

// Solo asesorados propios
const athlete = await getOwnedAthlete(coach.id, athleteId);
if (!athlete) return Astro.redirect("/coach");

const [intake, program, historyResult, nutritionWeek, targets, library] = await Promise.all([
  getAthleteIntake(athleteId),
  getActiveProgramWithSchedule(athleteId),
  getWorkoutHistory(athleteId),
  getWeeklyNutritionSummary(athleteId),
  getActiveNutritionTargets(athleteId),
  getProgramLibrary(coach.id),
]);
const mealPlan = await getActiveMealPlan(athleteId);

const sessions = (historyResult.data ?? []).map(s => ({
  ...s,
  startedAt: s.startedAt ? new Date(s.startedAt).toISOString() : new Date().toISOString(),
}));

const DAY_ABBR = ["D", "L", "M", "X", "J", "V", "S"];
const trainingDays = program ? program.schedule.filter(d => !d.isRest).length : 0;
---

<MainLayout title={`${athlete.displayName ?? "Atleta"} — Coach`} description="Detalle del asesorado: evaluacion, programa, entrenamiento y nutricion.">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10 space-y-8">

    <!-- Header -->
    <div class="space-y-4">
      <a href="/coach" class="inline-flex items-center gap-2 text-[9px] font-black text-white/30 hover:text-white/60 uppercase tracking-[0.3em] transition-colors">
        ← Asesorados
      </a>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div class="space-y-1">
          <p class="text-[9px] font-black text-blue-500/60 uppercase tracking-[0.4em]">ASESORADO</p>
          <h1 class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter leading-[0.95]">
            {athlete.displayName ?? "Atleta"}
          </h1>
          <p class="text-[10px] font-bold text-white/25 uppercase tracking-widest pt-1">{athlete.email}</p>
        </div>
      </div>
    </div>

    <!-- Evaluacion inicial -->
    <IntakeReview
      athleteId={athlete.id}
      intake={intake ? { goals: intake.goals, health: intake.health, lifestyle: intake.lifestyle, availability: intake.availability } : null}
      submittedAt={intake?.submittedAt?.toISOString() ?? null}
      reviewedAt={intake?.reviewedAt?.toISOString() ?? null}
      client:load
    />

    <div class="grid lg:grid-cols-3 gap-6 items-start">

      <!-- Registro de entrenamiento -->
      <div class="lg:col-span-2 space-y-4">
        <h2 class="text-xl font-black text-white uppercase tracking-tighter">Registro de entrenamiento</h2>
        <CoachWorkoutLog sessions={sessions} client:load />
      </div>

      <!-- Sidebar: programa + nutricion -->
      <div class="space-y-6 lg:sticky lg:top-28">

        <!-- Programa -->
        <div class="p-6 rounded-[2rem] bg-[#0A0A0B] border border-white/10 space-y-4">
          <p class="text-[9px] font-black text-white/25 uppercase tracking-[0.3em]">Programa actual</p>
          {program ? (
            <div class="space-y-3">
              <div>
                <p class="text-lg font-black text-white uppercase tracking-tighter leading-tight">{program.name}</p>
                <p class="text-[9px] font-black text-white/30 uppercase tracking-widest mt-1">
                  {[program.level, program.focus, `${trainingDays} dias/sem`].filter(Boolean).join(" · ")}
                </p>
              </div>
              <div class="space-y-1.5">
                <div class="flex items-center justify-between">
                  <span class="text-[9px] font-black text-white/40 uppercase tracking-widest">Semana {program.currentWeek} de {program.durationWeeks}</span>
                  <span class="text-[9px] font-black text-blue-400 tabular-nums">{Math.round((program.currentWeek / program.durationWeeks) * 100)}%</span>
                </div>
                <div class="h-1.5 rounded-full bg-white/[0.05] overflow-hidden">
                  <div class="h-full bg-blue-600" style={`width: ${Math.min(100, Math.round((program.currentWeek / program.durationWeeks) * 100))}%`}></div>
                </div>
              </div>
            </div>
          ) : (
            <p class="text-sm font-black text-orange-400/80 uppercase tracking-tight">Sin programa asignado</p>
          )}

          <AssignProgram
            athleteId={athlete.id}
            templates={library.map(t => ({ id: t.id, name: t.name, isMaster: t.isMaster, trainingDays: t.trainingDays, durationWeeks: t.durationWeeks }))}
            currentProgramName={program?.name ?? null}
            client:load
          />
        </div>

        <!-- Plan alimenticio -->
        <div class="p-6 rounded-[2rem] bg-[#0A0A0B] border border-white/10 space-y-3">
          <p class="text-[9px] font-black text-white/25 uppercase tracking-[0.3em]">Plan alimenticio</p>
          {mealPlan ? (
            <div class="space-y-1">
              <p class="text-lg font-black text-white uppercase tracking-tighter leading-tight">{mealPlan.name}</p>
              <p class="text-[9px] font-black text-white/30 uppercase tracking-widest tabular-nums">
                {mealPlan.meals.length} comidas · {mealPlan.calories} kcal · {mealPlan.proteinG}P
              </p>
            </div>
          ) : (
            <p class="text-sm font-black text-orange-400/80 uppercase tracking-tight">Sin plan asignado</p>
          )}
          <a
            href={`/coach/athletes/${athlete.id}/nutrition`}
            class="block w-full py-2.5 rounded-xl text-center text-[9px] font-black uppercase tracking-widest bg-blue-600/20 border border-blue-500/40 text-blue-300 hover:bg-blue-600/35 transition-all"
          >
            {mealPlan ? "Editar plan" : "Crear plan"}
          </a>
        </div>

        <!-- Nutricion: ultimos 7 dias -->
        <div class="p-6 rounded-[2rem] bg-[#0A0A0B] border border-white/10 space-y-4">
          <div class="flex items-baseline justify-between">
            <p class="text-[9px] font-black text-white/25 uppercase tracking-[0.3em]">Combustible · 7 dias</p>
            {targets && (
              <p class="text-[9px] font-black text-white/30 uppercase tracking-widest tabular-nums">
                Meta {targets.calories} kcal · {targets.proteinG}P
              </p>
            )}
          </div>
          <ul class="divide-y divide-white/[0.05]">
            {nutritionWeek.map((d) => {
              const date = new Date(d.date + "T00:00:00");
              const hitKcal = targets ? d.kcal >= targets.calories * 0.9 && d.kcal <= targets.calories * 1.1 : false;
              return (
                <li class="py-2 flex items-center justify-between gap-3">
                  <span class="text-[9px] font-black text-white/30 uppercase tracking-widest w-8">
                    {DAY_ABBR[date.getDay()]} {date.getDate()}
                  </span>
                  {d.kcal === 0 ? (
                    <span class="text-[9px] font-black text-white/15 uppercase tracking-widest">Sin registros</span>
                  ) : (
                    <span class={`text-[10px] font-black tabular-nums ${hitKcal ? "text-emerald-400" : "text-white/60"}`}>
                      {Math.round(d.kcal)} kcal · {Math.round(d.prot)}P · {Math.round(d.carbs)}C · {Math.round(d.fats)}G
                    </span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      </div>
    </div>

    <div class="h-16 md:h-0"></div>
  </div>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import { MealPlanEditor } from "@/components/coach/MealPlanEditor";
import { getOwnedAthlete } from "@/lib/db/coach";
import { getActiveMealPlan } from "@/lib/db/mealPlans";

const coach = Astro.locals.user!;
const athleteId = Astro.params.id!;

const athlete = await getOwnedAthlete(coach.id, athleteId);
if (!athlete) return Astro.redirect("/coach");

const plan = await getActiveMealPlan(athleteId);
---

<MainLayout title={`Plan alimenticio — ${athlete.displayName ?? "Atleta"}`} description="Diseña y asigna el plan alimenticio del asesorado.">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10 space-y-8">

    <!-- Header -->
    <div class="space-y-4">
      <a href={`/coach/athletes/${athlete.id}`} class="inline-flex items-center gap-2 text-[9px] font-black text-white/30 hover:text-white/60 uppercase tracking-[0.3em] transition-colors">
        ← {athlete.displayName ?? "Atleta"}
      </a>
      <div class="space-y-1">
        <p class="text-[9px] font-black text-orange-500/60 uppercase tracking-[0.4em]">COMBUSTIBLE</p>
        <h1 class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter leading-[0.95]">
          Plan<span class="text-white/20"> Alimenticio</span>
        </h1>
        <p class="text-white/30 text-xs font-bold uppercase tracking-widest pt-1 max-w-xl">
          Las metas del plan se convierten en los objetivos diarios del atleta. El registrara cada comida desde Combustible.
        </p>
      </div>
    </div>

    <MealPlanEditor
      athleteId={athlete.id}
      athleteName={athlete.displayName ?? "Atleta"}
      initialPlan={plan}
      client:load
    />
    <div class="h-16 md:h-0"></div>
  </div>
</MainLayout>

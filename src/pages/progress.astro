---
import MainLayout from "@/layouts/MainLayout.astro";
import { ProgressTracker } from "@/components/progress/ProgressTracker";

const { userId } = Astro.locals.auth();
---

<MainLayout title="Laboratorio de Progreso">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10 space-y-10">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div class="space-y-1">
        <p class="text-[9px] font-black text-blue-500/60 uppercase tracking-[0.4em]">ANÁLISIS DE RENDIMIENTO</p>
        <p class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter leading-[0.95]">
          Laboratorio<br class="sm:hidden" /><span class="text-white/20"> de Progreso</span>
        </p>
      </div>
      <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white/[0.03] border border-white/[0.07] w-fit">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-[9px] font-black text-white/30 uppercase tracking-widest">SISTEMA ACTIVO</span>
      </div>
    </div>

    <!-- Progress Tracker Component -->
    {userId && <ProgressTracker userId={userId} client:load />}

    <div class="h-16 md:h-0"></div>
  </div>
</MainLayout>

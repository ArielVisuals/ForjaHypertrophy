---
import MainLayout from "@/layouts/MainLayout.astro";
import { AssignedProgram } from "@/components/program/AssignedProgram";
import { getActiveProgramWithSchedule } from "@/lib/db/programs";
import { db } from "@/lib/db";
import { users } from "@/lib/db/schema";
import { eq } from "drizzle-orm";

const user = Astro.locals.user;

const program = user ? await getActiveProgramWithSchedule(user.id) : null;

let coachName: string | null = null;
if (user?.coachId) {
  const [coach] = await db
    .select({ displayName: users.displayName })
    .from(users)
    .where(eq(users.id, user.coachId))
    .limit(1);
  coachName = coach?.displayName ?? null;
}
---

<MainLayout title="Mi Programa" description="Tu programa de entrenamiento asignado: mesociclo, calendario semanal y prescripcion de cada dia.">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10 space-y-10">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div class="space-y-1">
        <p class="text-[9px] font-black text-blue-500/60 uppercase tracking-[0.4em]">PLANIFICACIÓN</p>
        <p class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter leading-[0.95]">
          Mi<span class="text-white/20"> Programa</span>
        </p>
      </div>
      <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white/[0.03] border border-white/[0.07] w-fit">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
        <span class="text-[9px] font-black text-white/30 uppercase tracking-widest">MESOCICLO</span>
      </div>
    </div>

    <AssignedProgram program={program} coachName={coachName} client:load />
    <div class="h-16 md:h-0"></div>
  </div>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import { WorkoutTracker } from "@/components/workout/WorkoutTracker";
import { db } from "@/lib/db";
import { trainingPrograms } from "@/lib/db/schema";
import { eq, and } from "drizzle-orm";
import { getTodayCompletedSession } from "@/lib/db/workouts";

const { userId } = Astro.locals.auth();

let initialProgram = null;
let todaySession   = null;

if (userId) {
  const [activeResult, todayResult] = await Promise.all([
    db.query.trainingPrograms.findFirst({
      where: and(eq(trainingPrograms.userId, userId), eq(trainingPrograms.active, true)),
    }),
    getTodayCompletedSession(userId),
  ]);

  if (activeResult) {
    initialProgram = {
      id:            activeResult.id,
      name:          activeResult.name ?? "",
      splitType:     activeResult.splitType ?? "",
      currentWeek:   activeResult.currentWeek ?? 1,
      durationWeeks: activeResult.durationWeeks ?? 12,
    };
  }

  if (todayResult.data) {
    todaySession = {
      ...todayResult.data,
      completedAt: todayResult.data.completedAt.toISOString(),
    };
  }
}
---

<MainLayout title="Entrenar">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10">

    <!-- Page Header -->
    <div class="mb-6 md:mb-10">
      <p class="text-[9px] font-black text-blue-500/40 uppercase tracking-[0.4em] mb-1 hidden sm:block">
        FORJA / ENTRENAMIENTO
      </p>
      <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tighter leading-none">
        ENTRENAR
      </h1>
    </div>

    {userId && (
      <WorkoutTracker
        userId={userId}
        initialProgram={initialProgram}
        todaySession={todaySession}
        client:load
      />
    )}
  </div>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import { WorkoutTracker } from "@/components/workout/WorkoutTracker";
import { getTodayCompletedSession } from "@/lib/db/workouts";
import { getActiveProgramWithSchedule } from "@/lib/db/programs";

const userId = Astro.locals.user?.id ?? null;

let initialProgram = null;
let todaySession   = null;

if (userId) {
  const [activeProgram, todayResult] = await Promise.all([
    getActiveProgramWithSchedule(userId),
    getTodayCompletedSession(userId),
  ]);

  initialProgram = activeProgram;

  if (todayResult.data) {
    todaySession = {
      ...todayResult.data,
      completedAt: todayResult.data.completedAt.toISOString(),
    };
  }
}
---

<MainLayout title="Entrenar" description="Registra tu entrenamiento — series, repeticiones, RPE y notas. El Arquitecto analiza cada sesión con inteligencia artificial.">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10">

    <!-- Page Header -->
    <div class="mb-6 md:mb-10">
      <p class="text-[9px] font-black text-blue-500/40 uppercase tracking-[0.4em] mb-1 hidden sm:block">
        FORJA / ENTRENAMIENTO
      </p>
      <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tighter leading-none">
        ENTRENAR
      </h1>
    </div>

    {userId && (
      <WorkoutTracker
        initialProgram={initialProgram}
        todaySession={todaySession}
        client:load
      />
    )}
  </div>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import { WorkoutTracker } from "@/components/workout/WorkoutTracker";
import { db } from "@/lib/db";
import { trainingPrograms } from "@/lib/db/schema";
import { eq, and } from "drizzle-orm";
const { userId } = Astro.locals.auth();

let initialProgram = null;

if (userId) {
  const active = await db.query.trainingPrograms.findFirst({
    where: and(eq(trainingPrograms.userId, userId), eq(trainingPrograms.active, true)),
  });
  if (active) {
    initialProgram = {
      id:            active.id,
      name:          active.name ?? "",
      splitType:     active.splitType ?? "",
      currentWeek:   active.currentWeek ?? 1,
      durationWeeks: active.durationWeeks ?? 12,
    };
    // getTodaysProgramDay se ejecuta en el cliente (hora local del usuario, no UTC del servidor)
  }
}
---

<MainLayout title="Entrenar">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10">

    <!-- Page Header -->
    <div class="mb-6 md:mb-10">
      <p class="text-[9px] font-black text-blue-500/40 uppercase tracking-[0.4em] mb-1 hidden sm:block">
        FORJA / ENTRENAMIENTO
      </p>
      <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tighter leading-none">
        ENTRENAR
      </h1>
    </div>

    {userId && (
      <WorkoutTracker
        userId={userId}
        initialProgram={initialProgram}
        client:load
      />
    )}
  </div>
</MainLayout>

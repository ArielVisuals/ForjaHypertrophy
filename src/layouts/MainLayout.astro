---
import "../styles/global.css";
import { UserMenu } from "@/components/shared/UserMenu";
import { LandingHeader } from "@/components/shared/LandingHeader";
import { MobileMenu } from "@/components/shared/MobileMenu";
import { clerkClient } from "@clerk/astro/server";

interface Props {
  title: string;
  description?: string;
  showHeader?: boolean;
}

const { title, description = "Aplicación de seguimiento de hipertrofia", showHeader = true } = Astro.props;
const currentPath = Astro.url.pathname;

// Obtener datos del usuario desde el servidor (Astro)
const { userId } = Astro.locals.auth();
let user = null;
let isSignedIn = !!userId;

if (userId) {
  try {
    user = await clerkClient(Astro).users.getUser(userId);
  } catch (e) {
    console.error("Error fetching user from Clerk:", e);
    isSignedIn = false;
  }
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} - Forja Hypertrophy</title>
    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="FORJA" />
    <meta name="theme-color" content="#0A0A0B" />
    <meta name="mobile-web-app-capable" content="yes" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen relative overflow-x-hidden">
    <!-- Background con gradiente -->
    <div class="fixed inset-0 bg-black"></div>
    <div class="fixed inset-0 bg-gradient-to-b from-transparent via-transparent to-blue-900/40"></div>

    <!-- Header dinámico — solo desktop (md+) -->
    {showHeader && (
      <header class="hidden md:block fixed top-[clamp(1rem,4vw,2rem)] left-0 right-0 z-50 px-6">
        <div class="max-w-7xl mx-auto flex justify-center">
          <div class="w-full rounded-full border border-white/10 backdrop-blur-md bg-white/[0.03] shadow-2xl shadow-black/50">
            <div class="flex items-center h-16 md:h-20 px-[clamp(1.5rem,4vw,2.5rem)] justify-between relative">
              
              <!-- Logo -->
              <div class="flex items-center gap-3 shrink-0">
                <a href={isSignedIn ? "/dashboard" : "/"} class="flex items-center gap-3">
                  <img src="/isotipo.png" alt="FORJA" class="h-[clamp(1.75rem,4vw,2.25rem)] w-auto" />
                  <span class="text-[clamp(1rem,2vw,1.25rem)] font-extrabold text-white tracking-tighter">FORJA</span>
                </a>
              </div>

              <!-- Navigation (Centered) -->
              <nav class="hidden lg:flex items-center absolute left-1/2 -translate-x-1/2">
                <div class="flex items-center gap-[clamp(1rem,2vw,2rem)]">
                  {isSignedIn ? (
                    <>
                      <a href="/dashboard" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/dashboard' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Dashboard</a>
                      <a href="/workout" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/workout' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Entrenar</a>
                      <a href="/progress" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/progress' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Progreso</a>
                      <a href="/program" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/program' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Programas</a>
                      <a href="/nutrition" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/nutrition' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Nutrición</a>
                      <a href="/settings" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/settings' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Ajustes</a>
                    </>
                  ) : (
                    <>
                      <a href="/#features" class="text-white/50 hover:text-white text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em]">Características</a>
                      <a href="/#pricing" class="text-white/50 hover:text-white text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em]">Precios</a>
                      <a href="/#about" class="text-white/50 hover:text-white text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em]">Acerca</a>
                    </>
                  )}
                </div>
              </nav>

              <!-- User Menu / Auth -->
              <div class="flex items-center gap-4 relative z-10">
                <UserMenu user={user} isSignedIn={isSignedIn} client:load />
              </div>

            </div>
          </div>
        </div>
      </header>
    )}

    <main class="relative z-10 min-h-screen pt-6 md:pt-32 pb-28 md:pb-0">
      <slot />
    </main>

    <!-- Mobile Menu (nav + sheet) — solo móvil, solo logueado -->
    <MobileMenu
      currentPath={currentPath}
      user={user}
      isSignedIn={isSignedIn}
      client:load
    />
  </body>
</html>

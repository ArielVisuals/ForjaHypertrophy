---
import "../styles/global.css";
import { UserMenu } from "@/components/shared/UserMenu";
import { LandingHeader } from "@/components/shared/LandingHeader";
import { MobileMenu } from "@/components/shared/MobileMenu";

interface Props {
  title: string;
  description?: string;
  showHeader?: boolean;
}

const { title, description = "Aplicación de seguimiento de hipertrofia", showHeader = true } = Astro.props;
const currentPath = Astro.url.pathname;

// locals.user lo resuelve el middleware (JWT propio)
const appUser = Astro.locals.user ?? null;
const isCoach = appUser?.role === "coach";
const isSignedIn = !!appUser;
const user = appUser ? { displayName: appUser.displayName, email: appUser.email } : null;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{title} - Forja Hypertrophy</title>
    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="FORJA" />
    <meta name="theme-color" content="#0A0A0B" />
    <meta name="mobile-web-app-capable" content="yes" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    </noscript>
  </head>
  <body class="min-h-screen relative overflow-x-hidden">
    <!-- Background con gradiente -->
    <div class="fixed inset-0 bg-black"></div>
    <div class="fixed inset-0 bg-gradient-to-b from-transparent via-transparent to-blue-900/40"></div>

    <!-- Header dinámico — solo desktop (md+) -->
    {showHeader && (
      <header class="hidden md:block fixed top-[clamp(1rem,4vw,2rem)] left-0 right-0 z-50 px-6">
        <div class="max-w-7xl mx-auto flex justify-center">
          <div class="w-full rounded-full border border-white/10 backdrop-blur-md bg-white/[0.03] shadow-2xl shadow-black/50">
            <div class="flex items-center h-16 md:h-20 px-[clamp(1.5rem,4vw,2.5rem)] justify-between relative">
              
              <!-- Logo -->
              <div class="flex items-center gap-3 shrink-0">
                <a href={isCoach ? "/coach" : isSignedIn ? "/dashboard" : "/"} class="flex items-center gap-3">
                  <img src="/isotipo-96.webp" alt="" width="96" height="96" class="h-[clamp(1.75rem,4vw,2.25rem)] w-auto" />
                  <span class="text-[clamp(1rem,2vw,1.25rem)] font-extrabold text-white tracking-tighter">FORJA</span>
                </a>
              </div>

              <!-- Navigation (Centered) -->
              <nav class="hidden lg:flex items-center absolute left-1/2 -translate-x-1/2">
                <div class="flex items-center gap-[clamp(1rem,2vw,2rem)]">
                  {isSignedIn ? (
                    <>
                      {isCoach && (
                        <a href="/coach" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath.startsWith('/coach') && !currentPath.startsWith('/coach/programs') ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Asesorados</a>
                      )}
                      {isCoach && (
                        <a href="/coach/programs" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath.startsWith('/coach/programs') ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Biblioteca</a>
                      )}
                      {!isCoach && <a href="/dashboard" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/dashboard' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Dashboard</a>}
                      {!isCoach && <a href="/workout" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/workout' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Entrenar</a>}
                      {!isCoach && <a href="/progress" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/progress' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Progreso</a>}
                      {!isCoach && <a href="/program" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/program' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Programas</a>}
                      {!isCoach && <a href="/nutrition" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/nutrition' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Nutrición</a>}
                      {!isCoach && <a href="/settings" class={`text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em] transition-all ${currentPath === '/settings' ? 'text-blue-400' : 'text-white/50 hover:text-white'}`}>Ajustes</a>}
                    </>
                  ) : (
                    <>
                      <a href="/#features" class="text-white/50 hover:text-white text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em]">Características</a>
                      <a href="/#pricing" class="text-white/50 hover:text-white text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em]">Precios</a>
                      <a href="/#about" class="text-white/50 hover:text-white text-[clamp(0.65rem,1.2vw,0.75rem)] font-bold uppercase tracking-[0.2em]">Acerca</a>
                    </>
                  )}
                </div>
              </nav>

              <!-- User Menu / Auth -->
              <div class="flex items-center gap-4 relative z-10">
                <UserMenu user={user} isSignedIn={isSignedIn} client:load />
              </div>

            </div>
          </div>
        </div>
      </header>
    )}

    <main class={`relative z-10 min-h-screen ${showHeader ? "pt-6 md:pt-32" : "pt-6 md:pt-10"} pb-28 md:pb-0`}>
      <slot />
    </main>

    <!-- Mobile Menu (nav + sheet) — solo móvil, solo logueado -->
    <MobileMenu
      currentPath={currentPath}
      user={user}
      isSignedIn={isSignedIn}
      isCoach={isCoach}
      client:load
    />

    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>

    <script>
      import { syncQueue } from "@/lib/offlineQueue";

      async function trySyncOfflineQueue() {
        try {
          const { synced } = await syncQueue();
          if (synced > 0) console.log(`[FORJA] ${synced} operación(es) offline sincronizada(s)`);
        } catch {}
      }

      // Sync on every page load (catches the "went home, opened dashboard" case)
      if (navigator.onLine) trySyncOfflineQueue();

      // Also sync when connection returns
      window.addEventListener("online", trySyncOfflineQueue);
    </script>
  </body>
</html>

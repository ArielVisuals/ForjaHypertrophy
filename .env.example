# Supabase Configuration (OBSOLETE - MIGRATED TO NEON/CLERK)
# PUBLIC_SUPABASE_URL=your-project-url.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Neon Database
DATABASE_URL=postgresql://user:password@ep-host.region.aws.neon.tech/neondb?sslmode=require

# Auth propia (JWT) — genera con: openssl rand -base64 48
AUTH_SECRET=un-secreto-largo-y-aleatorio
# Codigo que convierte un registro en cuenta de entrenador
COACH_INVITE_CODE=FORJA-COACH-0000

# App Configuration
PUBLIC_APP_URL=http://localhost:4321

# Resend (correos transaccionales: verificacion y reset de contraseña)
RESEND_API_KEY=re_...
# Remitente con dominio verificado en Resend
EMAIL_FROM="FORJA <noreply@tudominio.com>"
